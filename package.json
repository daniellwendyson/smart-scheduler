{
  "name": "smart-scheduler",
  "version": "1.0.0",
  "private": true,
  "description": "Service appointment scheduling system.",
  "scripts": {
    "dev:backend": "cross-env NODE_ENV=development nodemon backend/server.js",
    "start": "node backend/server.js",
    "services:up": "docker compose -f compose.yaml up -d",
    "services:stop": "docker compose -f compose.yaml stop",
    "services:down": "docker compose -f compose.yaml down",
    "migrations:create": "node-pg-migrate -m backend/migrations create",
    "migrations:up": "node-pg-migrate -m backend/migrations --envPath .env.development up",
    "migrations:down": "node-pg-migrate -m backend/migrations --envPath .env.development down",
    "migrations:up:test": "node-pg-migrate -m backend/migrations --envPath .env.test up",
    "migrations:down:test": "node-pg-migrate -m backend/migrations --envPath .env.test down",
    "test": "cross-env NODE_ENV=test npm run migrations:up:test && cross-env NODE_ENV=test jest --runInBand --verbose",
    "test:ci": "cross-env NODE_ENV=test jest --runInBand --verbose",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky",
    "commit": "cz"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
